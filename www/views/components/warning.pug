// server side error modal
div(id="warning" class="modal fade" role="dialog")
	div(class="modal-dialog")
		div(class="modal-content")
			div(class="modal-header")
				button(class="close" data-dismiss="modal") &times;
				h2(class="modal-title") Whoops...
				p Have you verified every thing you filled in is valid?
			div(class="modal-body" style="text-align:center;vertical-align:middle;overflow:hidden;")
				div(class="form-group")
					div(class="col-md-2 col-md-2 col-xs-12") 
						button(class="btn btn-primary",style="background-color:#7fbb03;color:white;border-style:hidden;",id="copyError",onclick="copyToClipboard(`#error`);") copy
					div(class="col-md-10 col-md-10 col-xs-12")
						textarea(class="form-control", id="error", name="error", rows="20")
			div(class="modal-footer")
				a(href="mailto:***REMOVED***;jmtroy2@illinois.edu;npvance2@illinois.edu;jtyun@illinois.edu",target="_blank")
					button(class="btn btn-primary",style="background-color:#ea4a36;color:white;border-style:hidden;margin:3px 3px;",id="reportButton") Report the Error
				button(class="btn btn-default",style="background-color:#1e325a;color:white;border-style:hidden;margin:3px 3px", data-dismiss="modal") Close				
				
script.
	/*------------------------copy the error ---------------------------*/
	function copyToClipboard(textID) {
		$(textID).select();
		//console.log($(textID).select());
		document.execCommand('copy');
	}
	

