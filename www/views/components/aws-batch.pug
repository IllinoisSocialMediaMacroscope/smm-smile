div(id="aws-batch" class="modal fade" role="dialog" data-backdrop="static" data-keyboard="false")
	div(class="modal-dialog")
		div(class="modal-content")
			div(class="modal-header")
				button(class="close", data-dismiss="modal") &times;
				h3(class="modal-title", id="modal-title", style="text-align:left;") Non-realtime Computation
			
			div(class="modal-body" style="vertical-align:middle;margin-left:20px; margin-right:20px;overflow:auto;")
				div(id="modal-message")
					p Your selected dataset size exceed the limit for real-time process. We will have to place this on a job queue.
						| Once your computation job has succeeded, we will email you with instructions to review your results.
					div(class="form-group")
						div(class="col-md-4 col-md-4 col-xs-12")
							img(src="bootstrap/img/logo/no-termination.PNG",style="width:150px; margin-top:5px;") 
						div(class="col-md-8 col-md-8 col-xs-12")
							img(src="bootstrap/img/gifs/warning.gif",style="width:10px;") 
							p(style="display:inline;color:red;") You may feel free to leave this page or close your browser. BUT DO NOT TERMINATE THIS SESSION AFTER SUBMITTING THIS JOB! 
					div(class="form-group")
						label(class="control-label col-md-4 col-md-4 col-xs-12",for="") Dataset
						div(class="col-md-8 col-md-8 col-xs-12")
							input(class="form-control dataset",disabled)
					div(class="form-group")
						label(class="control-label col-md-4 col-md-4 col-xs-12",for="") Number of posts
						div(class="col-md-8 col-md-8 col-xs-12")
							input(class="form-control length",disabled)
					div(class="form-group")
						label(class="control-label col-md-4 col-md-4 col-xs-12",for="") Email Address
						div(class="col-md-8 col-md-8 col-xs-12")
							input(id="batch-email-alert", class="form-control", type="email", name="email-alert")
			div(class="modal-footer")
				button(class="btn btn-primary",id="",style="background-color:#ea4a36;color:white;border-style:hidden;margin:3px 3px" onclick="ajaxSubmit(`#analytics-config`,`batch`)") Submit

div(id="aws-batch-confirmation", class="modal fade", role="dialog", data-backdrop="static", data-keyboard="false")
	div(class="modal-dialog")
		div(class="modal-content")
			div(class="modal-body",style="vertical-align:middle;margin-left:20px; margin-right:20px;overflow:auto;")
				div(id="modal-message")
					img(src="bootstrap/img/gifs/success.gif", class="export-success", width="80px")
					p(style="font-size:30px;") Your request has been submitted. You will receive an email and further instruction from us once it's done!
			div(class="modal-footer")
				button(class="btn btn-default",style="background-color:#1e325a;color:white;border-style:hidden",data-dismiss="modal") Close	

script(src="bootstrap/js/customized/view_aws_batch.js")
	