<!-- user -->
div(class="user")
	div(class="form-group")
		<label class="label-control warning">maximum number of users
			<span class="warningText">Careful! Every 20 count is ONE http request, and you only have 900 requests allowed over 15 minutes window</span></label>
		div(class="range range-node")
			input(type="range" min="20" max="1000" value="100" step="20" id="twtUser-count" onchange="twtUserRange.value=value")
			<output id="twtUserRange">100</output>
	
	div(class="form-group")
		<label class="label-control">Select Fields</label>
		br
		select(multiple,id="twtUserFields",class="fields")
			optgroup(label="BasicFields")
				option(value="author_id") author id
				option(value="author_id_str") author id str
				option(value="name") name
				option(value="screen_name") screen name
				option(value="description") description
				option(value="author_created_at") author created_at
				option(value="profile_image_url") profile image URL
				option(value="profile_banner_url") profile banner URL
				option(value="url") URL
				option(value="location") location
				option(value="tweets_count") tweets count
				option(value="followers_count") followers count
				option(value="friends_count") friends count
				option(value="listed_count") listed count
				option(value="favourites_count") favorites count
				option(value="statuses_count") statuses count
				option(value="time_zone") timezone
				option(value="protected") protected
				option(value="verified") verified
				option(value="is_translator") is translator
				option(value="contributors_enabled") contributors enabled
				option(value="geo_enabled") geo enabled
				option(value="lang") lang
			optgroup(label="UserTimeline")
				option(value="id") tweet id
				option(value="created_at") tweet created at
				option(value="text") text
				option(value="retweet_count") retweet_count
													