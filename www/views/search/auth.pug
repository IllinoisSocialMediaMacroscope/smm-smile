doctype html
html
	heads
		meta(charset="utf-8")
		meta(name="viewport", content="width=device-width, initial-scale=1")
		
		<!-- this is for bootstrap 3! -->
		link(href="../bootstrap/css/bootstrap.min.css", rel="stylesheet")
		script(src="https://ajax.googleapis.com/ajax/libs/jquery/3.2.1/jquery.min.js")
		
	body
		div(id="banner", style="margin:50px auto;text-align:center;")
			img(src=bannerURL,width="400px;")
		
		div(id="login", style="max-width:1000px;margin:auto auto;")
			div(class="col-md-6")
				h2 Authorize <b>SMILE</b> with:
				form(action=endpoint, method="post")
					div(class="form-group")
						input(name="reddit_username" id="user_login" class="form-control" type="text" maxlength="20" tabindex="3" placeholder="username" autofocus="")
					div(class="form-group")
						input(id="passwd_login" class="form-control" name="reddit_password" type="password" tabindex="3" placeholder="password")
					button(type="submit",class="btn btn-primary",style="margin:auto 10px;") Submit
					button(type="submit",class="btn btn-default",style="margin:auto 10px;",onclick="window.location.href='query'") Cancel
			
			
			div(class="col-md-6")
				h2 Allow  <b>SMILE</b>  to:
				div(class="app-permissions" style="background-color:#eee;border-radius:5px; padding:20px 20px;")
					ul
						each clause,i in clauses
							li #{clause}
							