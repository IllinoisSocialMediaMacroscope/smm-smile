{
	"form-action": "text-classification",
	"containers":[
		{"container-name":"file-container",
		"container-label-name":"select from your folder",
		"inputs":[
					{"type":"select",
						"name":"selectFile",
						"id":"selectFile",
						"sytle":"",
						"class":"form-control",
						"optgroup": true
					}
				]},
		{"container-name":"divider",
			"container-label-name":"",
			"inputs":[
				{"type":"divider"}
			]},

		{"container-name":"import-container",
			"container-label-name":"Import local file",
			"inputs":[
				{"type":"file",
					"name":"importFile",
					"id":"importFile",
					"style":"width: 0.1px; height: 0.1px; opacity: 0; overflow: hidden; position: absolute; z-index: -1;",
					"class":"form-control"
				}
			]},

		{"container-name":"select-task",
		"container-label-name":"Select Task",
		"inputs":[
					{"type":"select",
						"name":"task",
						"id":"task",
						"class":"form-control",
						"optgroup": false,
						"options":[
							{"value":"split",
							"label":"Step1 -- derive your training set from the corpus"},

							{"value":"train",
							"label":"Step2 -- train your classification model"},

							{"value":"predict",
							"label":" Step3 -- predict using your model"}
						]
					}
				]},
		{"container-classname":"split",
		"container-label-name":"Training dataset size (%)",
		"inputs":[
					{"type":"range",
						"min":"5",
						"max":"95",
						"value":"30",
						"name":"ratio",
						"id":"ratio",
						"onchange":"rangeNode.value=value",
						"output_id":"rangeNode"
					}
				]},

		{"container-classname":"train",
			"container-label-name":"Labeled training set",
			"inputs":[
				{
					"type":"file-upload",
					"id":"labeled",
					"name":"labeled",
					"displayname":"upload-fname",
					"style":"width: 0.1px; height: 0.1px; opacity: 0; overflow: hidden; position: absolute; z-index: -1;"
				}
			]},

		{
			"container-classname":"train",
			"container-label-name":"Select classification model",
			"inputs":[
				{"type":"select",
					"name":"classifier",
					"id":"classifier",
					"class":"form-control",
					"optgroup": false,
					"options":[
						{"value":"NaiveBayes",
							"label":"Naive Bayes classifier for multinomial models"},

						{"value":"Perceptron",
							"label":"Perceptron"},

						{"value":"SGD",
							"label":"Linear classifiers with stochastic gradient descent learning"},

						{"value":"RandomForest",
							"label":"Random forest classifier"},

						{"value":"KNN",
							"label":"K-nearest neighbors vote"},

						{"value":"passiveAggressive",
							"label":"Passive Aggressive Classifier"}
					]
				}
			]},

		{
			"container-classname":"uuid",
			"container-label-name":"Identification code",
			"inputs":[
				{
					"type":"uuid",
					"name":"uuid",
					"id":"uuid"
				}
			]
		}
	],
	"buttonGroups":[
		{
			"class":"btn btn-danger split",
			"value":"Split",
			"style":"margin: auto 5px;",
			"onclick":"split();"
		},
		{
			"class":"btn btn-danger train",
			"value":"Train",
			"style":"margin: auto 5px;",
			"onclick":"train();"
		},
		{
			"class":"btn btn-danger predict",
			"value":"Predict",
			"style":"margin: auto 5px;",
			"onclick":"predict();"
		},
		{
			"class":"btn btn-primary",
			"value":"Clear",
			"style":"margin: auto 5px;",
			"onclick":"customized_reset();"
		}
	],
	"custom-script":"bootstrap/js/customized/view_classification.js"
}
