{
	"form-action": "NLP-preprocess",
	"containers":[
		{"container-name":"file-container",
		"container-label-name":"Select from your folder",
		"inputs":[
					{"type":"select",
						"name":"selectFile",
						"id":"selectFile",
						"sytle":"",
						"class":"form-control",
						"optgroup": true
					}
				]},
		{"container-name":"divider",
			"container-label-name":"",
			"inputs":[
				{"type":"divider"}
			]},

		{"container-name":"import-container",
			"container-label-name":"Import local file",
			"inputs":[
				{"type":"file",
					"name":"importFile",
					"id":"importFile",
					"style":"width: 0.1px; height: 0.1px; opacity: 0; overflow: hidden; position: absolute; z-index: -1;",
					"class":"form-control"
				}
			]},
		{"container-name":"",
		"container-label-name":"Preprocess step",
		"inputs":[
					{"type":"select",
						"name":"model",
						"id":"model",
						"class":"form-control",
						"optgroup": false,
						"options":[
							{"value":"Please Select...",
							"label":"Please Select..."},

							{"value":"stemming",
							"label":"stemming"}
						]
					}
				]},
		{"container-name":"",
		"container-label-name":"Tagging",
		"inputs":[
					{"type":"select",
						"name":"tagger",
						"id":"tagger",
						"class":"form-control",
						"optgroup": false,
						"options":[
									{"value":"Please Select...",
									"label":"Please Select..."},
									
									{"value":"posTag",
									"label":"Natural Language Tool Kit Part of Speech Tagger"}]
					}
				]}
	],
	"buttonGroups":[
		{
			"id":"submit",
			"class":"btn btn-danger",
			"value":"Submit",
			"style":"margin: auto 5px;"
		},
		{
			"id":"clear",
			"class":"btn btn-primary",
			"value":"Clear",
			"style":"margin: auto 5px;",
			"onclick":"customized_reset();"
		}
	],
	"custom-script":"bootstrap/js/customized/view_preprocess.js"
}
